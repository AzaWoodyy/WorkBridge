{
  "name": "workbridge",
  "private": true,
  "version": "0.1.0",
  "main": "dist/main/index.cjs",
  "type": "module",
  "description": "WorkBridge desktop app",
  "author": "Enzo Neault",
  "scripts": {
    "dev": "env -u ELECTRON_RUN_AS_NODE electron-vite dev",
    "build": "electron-vite build",
    "preview": "env -u ELECTRON_RUN_AS_NODE electron-vite preview",
    "pack:mac": "node scripts/set-version.cjs && electron-vite build && electron-builder --mac",
    "postinstall": "electron-builder install-app-deps",
    "lint": "echo \"Add linting later\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-slot": "^1.0.2",
    "@tanstack/react-query": "^5.51.24",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "better-sqlite3": "^11.1.0",
    "drizzle-orm": "^0.36.4",
    "keytar": "^7.9.0",
    "emoji-toolkit": "^9.0.1",
    "react-markdown": "^9.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remark-gfm": "^4.0.0",
    "remark-emoji": "^4.0.0",
    "tailwind-merge": "^2.4.0",
    "zustand": "^4.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^2.3.0",
    "electron": "^31.2.0",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "electron-builder": "^24.13.3"
  },
  "productName": "WorkBridge",
  "build": {
    "appId": "com.workbridge.app",
    "productName": "WorkBridge",
    "files": [
      "dist/**",
      "package.json"
    ],
    "directories": {
      "buildResources": "build"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.png",
      "target": "dmg"
    }
  }
}
